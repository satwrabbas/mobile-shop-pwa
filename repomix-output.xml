    product.discount_price !== null && product.discount_price < product.price;

  return (
    <div className="space-y-8">
      {/* البطاقة الرئيسية للمنتج */}
      <div className="bg-white rounded-3xl p-6 md:p-10 shadow-sm border border-gray-100">
